{
  "name": "dt-dashboard-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "postinstall": "cpx \"node_modules/cesium/Build/Cesium/**\" public/cesium",
    "build:uibuilder": "bash build-uibuilder.sh",
    "deploy:uibuilder": "npm run build:uibuilder && cp -r out/* ~/.node-red/uibuilder/drone-map/src/",
    "deploy:remote": "bash deploy-remote.sh"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "cesium": "^1.139.0",
    "maplibre-gl": "^5.19.0",
    "mqtt": "^5.15.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.7.0",
    "three": "^0.183.2",
    "three-stdlib": "^2.36.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "babel-plugin-react-compiler": "1.0.0",
    "cpx": "^1.5.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "ws": "^8.19.0"
  }
}
