# Backend API endpoint
NEXT_PUBLIC_API_BASE=http://localhost:5000

# Cesium Ion token used for 3D map/terrain visualisation
NEXT_PUBLIC_CESIUM_ION_TOKEN=your_example_cesium_ion_token_here

# MapTiler key used for map tiles and geospatial rendering
NEXT_PUBLIC_MAPTILER_KEY=your_example_maptiler_key_here

# WebSocket endpoint for live camera stream
NEXT_PUBLIC_CAMERA_WS_URL=ws://localhost:38817/ws
